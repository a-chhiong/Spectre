// ===========================================================================
// PROJECT DEFINITION & DOCUMENTATION
// ===========================================================================

Project "Ecommerce_Platform" {
  database_type: 'PostgreSQL'
  Note: '''
    # E-commerce Database Schema
    This project defines the database schema for an e-commerce platform. It includes tables for managing users, products, orders, and more. The schema is designed to ensure data integrity and support the platform's operations efficiently.

    ## Key Features
    * **User Management**: Handles user accounts and authentication.
    * **Product Catalog**: Manages product listings and categories.
    * **Order Processing**: Supports order creation, tracking, and fulfillment.
    * **Promotions**: Allows for discount promotions and special offers.
  '''
}

// ===== ENUMS =====
Enum core.products_status {
  out_of_stock
  in_stock
  running_low [note: "less than 20"]
}

Enum core.orders_status {
  pending
  processing
  shipped
  canceled
}

// ===== TABLES =====

// --- CORE ---
Table core.users {
  id int [pk, increment, note: "Primary key for users"]
  full_name varchar [note: "User's full name"]
  email varchar [unique, note: "User email; used for login"]
  username varchar [unique, note: "Unique username"]
  password varchar [note: "Hashed password"]
  phone_number varchar [note: "Contact phone number"]
  last_login timestamp [note: "Last login timestamp"]
  avatar_url varchar [note: "Profile avatar URL"]
  created_at timestamp [note: "Account creation timestamp"]
  country_code int [note: "FK to info.countries.code"]

  Note: '''
  Stores platform users.
  - Primary identifiers: id, email, username.
  - country_code links to info.countries for locale.
  '''
}

Table core.merchants {
  id int [pk, increment, note: "Primary key for merchants"]
  country_code int [note: "FK to info.countries.code"]
  status core.orders_status [note: "Merchant status using orders_status enum"]
  merchant_name varchar [note: "Merchant display name"]
  address varchar [note: "Merchant address"]
  website_url varchar [note: "Merchant website"]
  phone_number varchar [note: "Merchant contact number"]
  email varchar [note: "Merchant contact email"]
  logo_url varchar [note: "Merchant logo image URL"]
  created_at datetime [note: "Merchant onboarding timestamp"]

  Note: '''
  Merchant records for sellers on the platform.
  - Use country_code to localize merchant data.
  '''
}

Table core.shipping_carriers {
  id int [pk, increment, note: "Primary key for carriers"]
  name varchar [note: "Carrier name (e.g., DHL)"]
  tracking_url varchar [note: "Carrier tracking URL template"]
  image_url varchar [note: "Carrier logo/image URL"]

  Note: '''
  Shipping carriers used for order fulfillment.
  - tracking_url may include placeholders for tracking numbers.
  '''
}

Table core.orders {
  id int [pk, increment, note: "Primary key for orders"]
  user_id int [note: "FK to core.users.id"]
  status core.orders_status [note: "Order lifecycle status"]
  created_at datetime [note: "Order placement timestamp"]
  total_price decimal [note: "Order total amount"]
  shipping_address varchar [note: "Shipping address snapshot"]
  billing_address varchar [note: "Billing address snapshot"]
  payment_method varchar [note: "Payment method used"]
  payment_status varchar [note: "Payment status (paid/failed/etc.)"]
  shipping_carrier_id int [note: "FK to core.shipping_carriers.id"]
  transaction_id varchar [note: "External payment transaction reference"]

  Note: '''
  Customer orders.
  - user_id links to the buyer.
  - Addresses and transaction_id are denormalized snapshots.
  '''
}

Table core.order_items {
  id int [pk, increment, note: "Primary key for order line items"]
  order_id int [note: "FK to core.orders.id"]
  product_id int [note: "FK to product.products.id (snapshot link)"]
  product_name varchar [note: "Product name snapshot at purchase"]
  quantity int [note: "Quantity ordered"]
  status core.orders_status [note: "Item-level status (uses orders_status enum)"]
  price decimal [note: "Unit price at purchase"]
  image_url varchar [note: "Product image snapshot URL"]

  Note: '''
  Line items for orders.
  - Denormalized fields (product_name, price) preserve historical data.
  '''
}

Table core.order_item_variants {
  id int [pk, increment, note: "Primary key for order item variants"]
  order_item_id int [note: "FK to core.order_items.id"]
  product_variant_id int [note: "FK to product.product_variants.id"]
  name varchar [note: "Variant label captured at purchase"]

  Note: '''
  Variant details for an order item (size, color, etc.).
  - Captures variant snapshot for the purchased item.
  '''
}

Table core.payment_transactions {
  id int [pk, increment, note: "Primary key for payment transactions"]
  order_id int [note: "FK to core.orders.id"]
  amount int [note: "Amount paid (integer or smallest currency unit)"]
  status varchar [note: "Transaction status from provider"]
  created_at datetime [note: "Transaction timestamp"]
  payment_method varchar [note: "Payment method used"]
  transaction_id varchar [note: "Provider transaction reference"]

  Note: '''
  Payment transaction records.
  - Keep one record per provider transaction.
  '''
}

Table core.promotions {
  id int [pk, increment, note: "Primary key for promotions"]
  name varchar [note: "Promotion name"]
  description varchar [note: "Promotion description"]
  discount_percentage decimal [note: "Discount percent (0-100)"]
  start_date datetime [note: "Promotion start datetime"]
  end_date datetime [note: "Promotion end datetime"]
  product_id int [note: "Optional FK to product.products.id for product-scoped promos"]

  Note: '''
  Promotions and discount campaigns.
  - product_id is optional; null means site-wide or category-level promo.
  '''
}

// --- INFO ---
Table info.countries {
  code int [pk, note: "Numeric country code (PK)"]
  name varchar [note: "Country name"]
  continent_name varchar [note: "Continent name"]

  Note: '''
  Reference table for countries.
  - Used by users and merchants via country_code.
  '''
}

// --- PRODUCT ---
Table product.products {
  id int [pk, increment, note: "Primary key for products"]
  name varchar [note: "Product title"]
  description varchar [note: "Product description"]
  brand varchar [note: "Brand name"]
  color varchar [note: "Primary color attribute"]
  weight float [note: "Weight (units defined by app)"]
  dimensions varchar [note: "Dimensions string (LxWxH)"]
  rating float [note: "Aggregated rating score"]
  merchant_id int [note: "FK to core.merchants.id"]
  price decimal [note: "Current price"]
  created_at datetime [note: "Product creation timestamp"]
  category_id int [note: "FK to product.categories.id"]
  expiry_date datetime [note: "Optional expiry or availability end date"]

  Note: '''
  Product catalog entries.
  - merchant_id links to the seller.
  - category_id organizes products into categories.
  '''
}

Table product.categories {
  id int [pk, increment, note: "Primary key for categories"]
  name varchar [note: "Category name"]
  parent_category_id int [note: "Self-referencing FK to product.categories.id"]
  created_at datetime [note: "Category creation timestamp"]

  Note: '''
  Product category hierarchy.
  - parent_category_id supports nested categories.
  '''
}

Table product.product_variants {
  id int [pk, increment, note: "Primary key for product variants"]
  name varchar [note: "Variant label (e.g., 'Red / L')"]
  product_id int [note: "FK to product.products.id"]

  Note: '''
  Variants for products (size, color, configuration).
  - Each variant belongs to a product.
  '''
}

Table product.product_tags {
  id int [pk, increment, note: "Primary key for product tags"]
  name varchar [note: "Tag name used for search and filtering"]

  Note: '''
  Tag definitions for product classification and search.
  '''
}

Table product.product_tags_map {
  product_id int [note: "FK to product.products.id"]
  tag_id int [note: "FK to product.product_tags.id"]

  indexes {
    (product_id, tag_id) [pk]
  }

  Note: '''
  Many-to-many mapping between products and tags.
  - Composite primary key on (product_id, tag_id).
  '''
}

// --- CART ---
Table cart.cart_items {
  id int [pk, increment, note: "Primary key for cart items"]
  user_id int [note: "FK to core.users.id"]
  product_id int [note: "FK to product.products.id"]
  quantity int [note: "Quantity in cart"]
  created_at datetime [note: "When item was added to cart"]

  Note: '''
  Shopping cart items per user.
  - One row per product per user cart.
  '''
}

// --- REVIEW ---
Table review.reviews {
  id int [pk, increment, note: "Primary key for reviews"]
  user_id int [note: "FK to core.users.id"]
  product_id int [note: "FK to product.products.id"]
  rating int [note: "Rating integer (e.g., 1-5)"]
  comment varchar [note: "Review text"]
  created_at datetime [note: "Review creation timestamp"]

  Note: '''
  Product reviews by users.
  - rating and comment stored for each review.
  '''
}

// --- WISHLIST ---
Table wishlist.wishlists {
  id int [pk, increment, note: "Primary key for wishlists"]
  user_id int [note: "FK to core.users.id"]
  name varchar [note: "Optional wishlist name"]
  created_at datetime [note: "Wishlist creation timestamp"]

  Note: '''
  Wishlist container per user.
  - Users can have multiple named wishlists.
  '''
}

Table wishlist.wishlist_items {
  id int [pk, increment, note: "Primary key for wishlist items"]
  wishlist_id int [note: "FK to wishlist.wishlists.id"]
  product_id int [note: "FK to product.products.id"]
  created_at datetime [note: "When item was added to wishlist"]

  Note: '''
  Items inside a wishlist.
  - Each row links a wishlist to a product.
  '''
}

// ===== TABLEGROUPS =====
TableGroup "Order Management" {
  core.orders
  core.order_items
  core.order_item_variants
  core.payment_transactions
  core.shipping_carriers
}

TableGroup "Product Management" {
  product.products
  product.categories
  product.product_variants
  product.product_tags
  product.product_tags_map
}

TableGroup "Wishlist Management" {
  wishlist.wishlists
  wishlist.wishlist_items
}

TableGroup "Cart Management" {
  cart.cart_items
}

TableGroup "Review Management" {
  review.reviews
}

TableGroup "Merchant & Promotions" {
  core.merchants
  core.promotions
}

TableGroup "Reference Data" {
  info.countries
}

// ===== RELATIONSHIPS (Refs) =====
Ref: core.users.country_code > info.countries.code
Ref: core.merchants.country_code > info.countries.code

// Category self-referencing hierarchy
Ref: product.categories.parent_category_id > product.categories.id

// Product dependencies
Ref: product.products.category_id > product.categories.id
Ref: product.products.merchant_id > core.merchants.id

// Product Variants & Tags
Ref: product.product_variants.product_id > product.products.id
Ref: product.product_tags_map.product_id > product.products.id
Ref: product.product_tags_map.tag_id > product.product_tags.id

// Order & Order Item links
Ref: core.orders.user_id > core.users.id
Ref: core.orders.shipping_carrier_id > core.shipping_carriers.id
Ref: core.order_items.order_id > core.orders.id
Ref: core.order_items.product_id > product.products.id
Ref: core.order_item_variants.order_item_id > core.order_items.id
Ref: core.order_item_variants.product_variant_id > product.product_variants.id

// Payments & Transactions
Ref: core.payment_transactions.order_id > core.orders.id

// Cart & Reviews
Ref: cart.cart_items.user_id > core.users.id
Ref: cart.cart_items.product_id > product.products.id
Ref: review.reviews.user_id > core.users.id
Ref: review.reviews.product_id > product.products.id

// Wishlists
Ref: wishlist.wishlists.user_id > core.users.id
Ref: wishlist.wishlist_items.wishlist_id > wishlist.wishlists.id
Ref: wishlist.wishlist_items.product_id > product.products.id

// Promotions
Ref: core.promotions.product_id > product.products.id