{
  "name": "@spectre/vscode-ext",
  "displayName": "Spectre",
  "description": "Preview Markdown, PlantUML, Mermaid diagrams, and OpenAPI specs directly in VS Code with syntax highlighting, zoom, and export.",
  "version": "0.0.5",
  "publisher": "a-chhiong",
  "icon": "media/icons/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "plantuml",
    "mermaid",
    "openapi",
    "swagger",
    "preview",
    "diagram"
  ],
  "activationEvents": [
    "onCommand:spectre.openPreview",
    "onLanguage:mermaid",
    "onLanguage:plantuml",
    "onLanguage:dbml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mermaid",
        "aliases": [
          "Mermaid",
          "mermaid"
        ],
        "extensions": [
          ".mmd",
          ".mermaid"
        ],
        "configuration": "./language-configuration/mermaid.json"
      },
      {
        "id": "plantuml",
        "aliases": [
          "PlantUML",
          "plantuml",
          "puml",
          "pu"
        ],
        "extensions": [
          ".puml",
          ".pu",
          ".plantuml"
        ],
        "configuration": "./language-configuration/plantuml.json"
      }
    ],
    "grammars": [
      {
        "language": "mermaid",
        "scopeName": "source.mermaid",
        "path": "./syntaxes/mermaid.tmLanguage.json"
      },
      {
        "scopeName": "markdown.mermaid.codeblock",
        "path": "./syntaxes/markdown-mermaid.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.mermaid": "mermaid"
        }
      },
      {
        "language": "plantuml",
        "scopeName": "source.wsd",
        "path": "./syntaxes/plantuml.tmLanguage.json"
      },
      {
        "scopeName": "markdown.plantuml.codeblock",
        "path": "./syntaxes/markdown-plantuml.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.plantuml": "plantuml"
        }
      }
    ],
    "commands": [
      {
        "command": "spectre.openPreview",
        "title": "Spectre: Open Preview",
        "icon": "$(preview)"
      },
      {
        "command": "spectre.toggleTheme",
        "title": "Spectre: Toggle Preview Theme",
        "icon": "$(color-mode)"
      }
    ],
    "viewsContainers": {
      "activitybar": []
    },
    "views": {},
    "menus": {
      "editor/title": [
        {
          "command": "spectre.openPreview",
          "when": "resourceExtname =~ /^\\.(md|markdown|puml|plantuml|pu|mmd|mermaid|yaml|yml|json|dbml)$/",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "spectre.toggleTheme",
          "when": "spectre.previewActive"
        }
      ]
    },
    "keybindings": [
      {
        "command": "spectre.openPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "resourceExtname =~ /^\\.(md|markdown|puml|plantuml|pu|mmd|mermaid|yaml|yml|json|dbml)$/"
      }
    ]
  },
  "scripts": {
    "compile": "tsc --noEmit",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src --ext .ts,.js",
    "prepackage": "node -e \"require('fs').copyFileSync('../LICENSE', 'LICENSE')\"",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@dbml/core": "^8.3.0",
    "@spectre/core": "*",
    "@lit/context": "^1.1.0",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "highlight.js": "^11.11.1",
    "html2pdf.js": "^0.14.0",
    "js-yaml": "^4.1.0",
    "lit": "^3.1.2",
    "marked": "^12.0.1",
    "mermaid": "^10.9.0",
    "rapipdf": "^2.2.1",
    "swagger-ui-dist": "latest"
  }
}
