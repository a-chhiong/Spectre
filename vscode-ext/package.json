{
  "name": "doctheatre",
  "displayName": "DocTheatre",
  "description": "Preview Markdown, PlantUML, Mermaid diagrams, and OpenAPI specs directly in VS Code with syntax highlighting, zoom, and export.",
  "version": "0.0.5",
  "publisher": "a-chhiong",
  "icon": "media/icons/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "plantuml",
    "mermaid",
    "openapi",
    "swagger",
    "preview",
    "diagram"
  ],
  "activationEvents": [
    "onCommand:doctheatre.openPreview",
    "onLanguage:mermaid",
    "onLanguage:plantuml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mermaid",
        "aliases": [
          "Mermaid",
          "mermaid"
        ],
        "extensions": [
          ".mmd",
          ".mermaid"
        ],
        "configuration": "./language-configuration/mermaid.json"
      },
      {
        "id": "plantuml",
        "aliases": [
          "PlantUML",
          "plantuml",
          "puml",
          "pu"
        ],
        "extensions": [
          ".puml",
          ".pu",
          ".plantuml"
        ],
        "configuration": "./language-configuration/plantuml.json"
      }
    ],
    "grammars": [
      {
        "language": "mermaid",
        "scopeName": "source.mermaid",
        "path": "./syntaxes/mermaid.tmLanguage.json"
      },
      {
        "scopeName": "markdown.mermaid.codeblock",
        "path": "./syntaxes/markdown-mermaid.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.mermaid": "mermaid"
        }
      },
      {
        "language": "plantuml",
        "scopeName": "source.wsd",
        "path": "./syntaxes/plantuml.tmLanguage.json"
      },
      {
        "scopeName": "markdown.plantuml.codeblock",
        "path": "./syntaxes/markdown-plantuml.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.plantuml": "plantuml"
        }
      }
    ],
    "commands": [
      {
        "command": "doctheatre.openPreview",
        "title": "DocTheatre: Open Preview",
        "icon": "$(preview)"
      },
      {
        "command": "doctheatre.exportSVG",
        "title": "DocTheatre: Export as SVG",
        "icon": "$(file-code)"
      },
      {
        "command": "doctheatre.exportPNG",
        "title": "DocTheatre: Export as PNG",
        "icon": "$(file-media)"
      },
      {
        "command": "doctheatre.exportHTML",
        "title": "DocTheatre: Export as HTML",
        "icon": "$(globe)"
      },
      {
        "command": "doctheatre.exportPDF",
        "title": "DocTheatre: Export as PDF",
        "icon": "$(file-pdf)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "doctheatre.openPreview",
          "when": "resourceExtname =~ /^\\.(md|markdown|puml|plantuml|pu|mmd|mermaid|yaml|yml|json)$/",
          "group": "navigation@1"
        },
        {
          "command": "doctheatre.exportSVG",
          "when": "doctheatre.previewActive && doctheatre.contentType =~ /^(plantuml|mermaid)$/",
          "group": "doctheatre.export@1"
        },
        {
          "command": "doctheatre.exportPNG",
          "when": "doctheatre.previewActive && doctheatre.contentType =~ /^(plantuml|mermaid)$/",
          "group": "doctheatre.export@2"
        },
        {
          "command": "doctheatre.exportHTML",
          "when": "doctheatre.previewActive",
          "group": "doctheatre.export@3"
        },
        {
          "command": "doctheatre.exportPDF",
          "when": "doctheatre.previewActive",
          "group": "doctheatre.export@4"
        }
      ],
      "commandPalette": [
        {
          "command": "doctheatre.exportSVG",
          "when": "doctheatre.previewActive"
        },
        {
          "command": "doctheatre.exportPNG",
          "when": "doctheatre.previewActive"
        },
        {
          "command": "doctheatre.exportHTML",
          "when": "doctheatre.previewActive"
        },
        {
          "command": "doctheatre.exportPDF",
          "when": "doctheatre.previewActive"
        }
      ]
    },
    "keybindings": [
      {
        "command": "doctheatre.openPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "resourceExtname =~ /^\\.(md|markdown|puml|plantuml|pu|mmd|mermaid|yaml|yml|json)$/"
      }
    ]
  },
  "scripts": {
    "compile": "tsc --noEmit",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src --ext .ts,.js",
    "prepackage": "node -e \"require('fs').copyFileSync('../LICENSE', 'LICENSE')\"",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.0",
    "marked": "^12.0.1",
    "mermaid": "^10.9.0",
    "rapipdf": "^2.2.1",
    "swagger-ui-dist": "latest"
  }
}
