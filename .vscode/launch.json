{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-ext"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-ext/out/**/*.js"
      ],
      "preLaunchTask": "npm: build-vscode-ext"
    }
  ]
}
